# LLM Provider
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_BASE_URL="https://aihubmix.com/v1"
MODEL_NAME=gpt-4o

# Embedding Provider (硅基流动 SiliconFlow)
EMBEDDING_API_KEY=your-siliconflow-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Pro/BAAI/bge-m3

# Redis (短期记忆)
REDIS_URL=redis://localhost:6379/0

# Vector Store (长期记忆)
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./vector_store/faiss_index
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# OpenTelemetry (全链路追踪)
OTEL_SERVICE_NAME=smart-cs-multi-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=always_on

# LangSmith (可选)
# LANGSMITH_API_KEY=ls-your-langsmith-key
# LANGSMITH_PROJECT=smart-cs-agent

# Server
HOST=0.0.0.0
PORT=8000
